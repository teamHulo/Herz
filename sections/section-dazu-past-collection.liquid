<style>
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .section-dazu-collection {
    position: relative;
  }
  .swiper-button-next::after, .swiper-button-prev::after {
    color: #000218;
  }
</style>

{% assign dazuCollectionTag = null %}
{% for tag in product.tags %}
  {% if tag contains 'Dazu passt Collection' %}
    {% assign dazuCollectionTag = tag | replace: 'Dazu passt Collection:', '' | handle %}
  {% endif %}
{% endfor %}
{% assign dazuCollection = collections[dazuCollectionTag] %}

{% assign metafield_products = product.metafields['shopify--discovery--product_recommendation'].complementary_products.value %}

{% if metafield_products and metafield_products.size > 0 or dazuCollectionTag != null and dazuCollection.products.size > 0 %}
  <div class="section-dazu-collection container">
    <h2 style="margin-top: 0;">{{ section.settings.title }}</h2>
    <div class="swiper list-products-swiper-2">
      <div class="swiper-wrapper" style="height: 100%">
        {% if metafield_products and metafield_products.size > 0 %}
          {% for product in metafield_products %}
            <div class="swiper-slide" style="height: auto;">
              {% render 'my-cart-item', section: section, product: product, show_contant: section.settings.show_contant, showButton: false %}
            </div>
          {% endfor %}
        {% endif %}
        {% if dazuCollectionTag != null %}
          {% for col_product in dazuCollection.products %}
            {% assign already_shown = false %}
            {% for meta_product in metafield_products %}
              {% if meta_product.id == col_product.id %}
                {% assign already_shown = true %}
              {% endif %}
            {% endfor %}
            {% unless already_shown %}
              <div class="swiper-slide" style="height: auto;">
                {% render 'my-cart-item', section: section, product: col_product, show_contant: section.settings.show_contant, showButton: false %}
              </div>
            {% endunless %}
          {% endfor %}
        {% endif %}
      </div>
    </div>
    <div class="swiper-button-next" style="display: block;"></div>
    <div class="swiper-button-prev" style="display: block;"></div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Dazu passt",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Paddind top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Paddind button",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "text",
      "id": "title",
      "label": "title"
    }
  ],
  "presets": [
    {
      "name": "Dazu passt"
    }
  ]
}
{% endschema %}
